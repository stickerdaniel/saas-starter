# @defaultSensitive=inferFromPrefix(PUBLIC_)
# @defaultRequired=infer
# @generateTypes(lang=ts, path=src/lib/convex/convex-env.d.ts)
# @redactLogs=true
# @preventLeaks=true
# ---

# ====================================
# Better Auth
# ====================================

# Secret for signing sessions and tokens
# @required @sensitive
BETTER_AUTH_SECRET=

# Base URL for OAuth redirects and deep links
# @type=url @required
SITE_URL=

# ====================================
# Email System (Resend)
# ====================================

# Resend API key for transactional email delivery
# @required @sensitive
RESEND_API_KEY=

# Sender email address for auth emails
# @required
AUTH_EMAIL=

# Production URL for email assets (logo images, footer links)
# Must always be a public domain (email clients cannot access localhost)
# @type=url @required
EMAIL_ASSET_URL=

# Resend webhook signing secret
# @optional @sensitive
RESEND_WEBHOOK_SECRET=

# ====================================
# Autumn Billing
# ====================================

# Autumn billing secret key
# @required @sensitive
AUTUMN_SECRET_KEY=

# ====================================
# AI Support
# ====================================

# OpenRouter API key for AI-powered support chat
# @required @sensitive
OPENROUTER_API_KEY=

# ====================================
# OAuth Providers
# ====================================

# Google OAuth
# @optional
AUTH_GOOGLE_ID=

# @optional @sensitive
AUTH_GOOGLE_SECRET=

# GitHub OAuth
# @optional
AUTH_GITHUB_ID=

# @optional @sensitive
AUTH_GITHUB_SECRET=

# ====================================
# E2E Testing
# ====================================

# Secret for test mutations (never set in production)
# @required @sensitive
AUTH_E2E_TEST_SECRET=

# ====================================
# Preview Dev (auto-seeded on preview deployments)
# ====================================

# Password for the auto-seeded preview admin (admin@preview.local)
# Only set on preview Convex deployments by vercel-deploy.ts
# @optional @sensitive
PREVIEW_ADMIN_PASSWORD=

# ====================================
# Local Dev (auto-generated by vite.config.ts)
# ====================================

# Flag indicating local Convex dev mode
# @type=boolean @optional
LOCAL_CONVEX_DEV=

# Seeded admin credentials for local dev
# @optional
LOCAL_SEEDED_ADMIN_EMAIL=

# @optional @sensitive
LOCAL_SEEDED_ADMIN_PASSWORD=

# @optional
LOCAL_SEEDED_ADMIN_NAME=
