{
	"name": "saas-starter",
	"version": "0.1.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:frontend": "vite dev",
		"dev:backend:cloud": "convex dev",
		"dev:cloud": "bun-tasks dev:frontend ::: dev:backend:cloud",
		"generate": "bun run convex codegen",
		"postinstall": "bun svelte-kit sync && varlock typegen && varlock typegen --path .env-convex.schema && bun run build:emails",
		"prebuild": "bun run build:emails",
		"build": "vite build",
		"generate:logos": "bun scripts/generate-logos.ts",
		"build:emails": "bun run generate:logos && tsx scripts/build-emails.ts",
		"preview": "vite preview",
		"prepare": "husky",
		"package": "bun svelte-kit sync && svelte-package",
		"check": "bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:convex": "tsc -p src/lib/convex/tsconfig.json --noEmit",
		"format": "prettier --write .",
		"lint": "eslint . --cache --concurrency auto && oxlint",
		"lint:convex": "oxlint",
		"knip": "knip",
		"static-checks": "bun scripts/static-checks.ts",
		"static-checks:staged": "bun scripts/static-checks.ts --staged",
		"test:e2e": "VARLOCK_ENV=test playwright test",
		"test:e2e:headed": "VARLOCK_ENV=test playwright test --headed",
		"test": "bun run test:e2e && bun run test:unit",
		"test:unit": "vitest --run --reporter=verbose --passWithNoTests",
		"i18n:pull": "varlock run -- bun run _tolgee:pull && prettier --write src/i18n/*.json",
		"i18n:push": "varlock run -- bun run _tolgee:push",
		"i18n:cleanup": "varlock run -- bun run _tolgee:cleanup",
		"_tolgee:pull": "TOLGEE_API_KEY=$VITE_TOLGEE_API_KEY tolgee pull",
		"_tolgee:push": "TOLGEE_API_KEY=$VITE_TOLGEE_API_KEY tolgee push",
		"_tolgee:cleanup": "TOLGEE_API_KEY=$VITE_TOLGEE_API_KEY tolgee tag --filter-not-extracted --filter-tag production --tag deprecated --untag production",
		"worktree": "bun scripts/create-worktree.ts",
		"worktree:setup": "bun scripts/create-worktree.ts --setup-only"
	},
	"dependencies": {
		"@better-auth/passkey": "^1.4.10",
		"@convex-dev/agent": "^0.3.0",
		"@convex-dev/better-auth": "^0.10.0",
		"@convex-dev/rate-limiter": "^0.3.2",
		"@convex-dev/resend": "^0.2.0",
		"@formkit/auto-animate": "^0.9.0",
		"@gilhrpenner/convex-files-control": "^0.5.1",
		"@humanspeak/svelte-markdown": "^1.0.4",
		"@mmailaender/convex-better-auth-svelte": "^0.5.0",
		"@openrouter/ai-sdk-provider": "^1.2.3",
		"@oslojs/crypto": "^1.0.1",
		"@rive-app/canvas": "^2.32.0",
		"@stickerdaniel/convex-autumn-svelte": "^0.1.3",
		"@svelte-put/lockscroll": "^2.0.1",
		"@tolgee/format-icu": "^6.2.7",
		"@tolgee/svelte": "^6.2.7",
		"@varlock/vite-integration": "^0.2.3",
		"@zumer/snapdom": "^2.0.0",
		"@zxcvbn-ts/core": "^3.0.4",
		"@zxcvbn-ts/language-common": "^3.0.4",
		"@zxcvbn-ts/language-en": "^3.0.2",
		"ai": "^5.0.93",
		"atmn": "^1.0.0",
		"autumn-js": "^0.1.43",
		"better-auth": "1.4.17",
		"better-svelte-email": "^1.3.0",
		"convex-helpers": "^0.1.108",
		"date-fns": "^4.1.0",
		"isomorphic-dompurify": "^3.0.0",
		"konva": "^10.0.8",
		"mode-watcher": "^1.1.0",
		"motion-sv": "^0.1.2",
		"paneforge": "^1.0.2",
		"posthog-js": "^1.290.0",
		"resend": "^6.5.2",
		"runed": "^0.37.0",
		"svelte-infinite": "^0.5.1",
		"svelte-konva": "^1.0.1",
		"svelte-streamdown": "^3.0.0",
		"svelte-toolbelt": "^0.10.6",
		"valibot": "^1.2.0",
		"varlock": "^0.5.0",
		"web-haptics": "^0.0.6"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.1",
		"@convex-dev/eslint-plugin": "1.2.1",
		"@eslint/compat": "2.0.3",
		"@eslint/js": "9.39.4",
		"@fontsource-variable/outfit": "^5.2.8",
		"@internationalized/date": "3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "1.58.2",
		"@resvg/resvg-js": "2.6.2",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@sveltejs/kit": "2.55.0",
		"@sveltejs/package": "2.5.7",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tabler/icons-svelte": "3.40.0",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.2.1",
		"@tanstack/table-core": "8.21.3",
		"@tolgee/cli": "^2.14.0",
		"@types/d3-scale": "4.0.9",
		"@types/d3-shape": "3.1.8",
		"@types/node": "25.5.0",
		"@typescript-eslint/eslint-plugin": "8.57.0",
		"@typescript-eslint/parser": "8.57.0",
		"bits-ui": "2.16.3",
		"bun-tasks": "0.1.2",
		"clsx": "^2.1.1",
		"convex": "1.33.1",
		"convex-svelte": "npm:@mmailaender/convex-svelte@0.17.1",
		"convex-vite-plugin": "^0.4.0",
		"d3-scale": "4.0.2",
		"d3-shape": "3.2.0",
		"eslint": "9.39.4",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.15.2",
		"formsnap": "2.0.1",
		"globals": "17.4.0",
		"husky": "9.1.7",
		"jose": "6.2.1",
		"jsdom": "28.1.0",
		"knip": "5.88.0",
		"layerchart": "2.0.0-next.43",
		"oxlint": "1.41.0",
		"oxlint-plugin-convex": "0.1.1",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"rollup-plugin-visualizer": "7.0.1",
		"svelte": "5.53.12",
		"svelte-check": "4.4.5",
		"svelte-sonner": "1.1.0",
		"sveltekit-superforms": "2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "4.2.1",
		"tsx": "4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vercel": "^50.0.0",
		"vite": "7.3.1",
		"vite-plugin-devtools-json": "1.0.0",
		"vitest": "4.1.0"
	},
	"patchedDependencies": {
		"oxlint-plugin-convex@0.1.1": "patches/oxlint-plugin-convex@0.1.1.patch"
	}
}
