# ====================================
# Convex Backend Environment Variables
# ====================================
# Source of truth: .env-convex.schema (varlock)
# Platform: Convex Dashboard (via CLI: bunx convex env set KEY value)
# Purpose: Backend configuration for Convex serverless functions
# For local dev: put values in .env.convex.local instead

# ====================================
# Email System (Resend) - REQUIRED for cloud email flows
# ====================================

# Resend API Key (REQUIRED for cloud / OPTIONAL for `bun run dev` boot)
# Get from: https://resend.com/api-keys
# Used for sending transactional emails (verification, password reset, etc.)
# Mirror this into `.env.local` only if you want real signup, verification, and reset emails
# while using `bun run dev`. Local boot itself can use the seeded admin without this.
# Command: bunx convex env set RESEND_API_KEY re_your_api_key_here
RESEND_API_KEY=re_your_api_key_here

# Auth Email Sender (REQUIRED for cloud / OPTIONAL for `bun run dev` boot)
# The "from" email address for authentication emails
# Must be a verified domain in Resend
# Example: noreply@yourdomain.com
# Mirror this into `.env.local` only if you want real Better Auth emails while using `bun run dev`.
# Command: bunx convex env set AUTH_EMAIL noreply@yourdomain.com
AUTH_EMAIL=noreply@yourdomain.com

# Resend Webhook Secret (OPTIONAL)
# Used to verify webhook requests from Resend
# Get from: Resend Dashboard → Webhooks → Signing Secret
# Enables webhook event tracking (delivery, bounces, complaints, opens, clicks)
# Command: bunx convex env set RESEND_WEBHOOK_SECRET whsec_your_secret_here
RESEND_WEBHOOK_SECRET=whsec_your_secret_here

# Email Asset URL (REQUIRED)
# Production URL for email assets (logo images, footer links)
# IMPORTANT: Always use production domain - email clients can't access localhost/preview URLs
# IMPORTANT: Must include the https:// protocol prefix, otherwise image src will be broken
# Note: For OAuth redirects, use SITE_URL (which can be preview URL)
# Command: bunx convex env set EMAIL_ASSET_URL https://yourdomain.com
EMAIL_ASSET_URL=https://yourdomain.com

# ====================================
# Better Auth (REQUIRED)
# ====================================

# Better Auth Secret (REQUIRED)
# Used for signing sessions and tokens
# Generate a secure random string (min 32 characters recommended)
# You can generate one with: openssl rand -base64 32
# Command: bunx convex env set BETTER_AUTH_SECRET your-secure-random-string-here
BETTER_AUTH_SECRET=your-secure-random-string-here

# ====================================
# OAuth (OPTIONAL)
# ====================================

# Google OAuth Client ID
# Get from: Google Cloud Console → APIs & Services → Credentials
# Required for Google Sign-In functionality
# Command: bunx convex env set AUTH_GOOGLE_ID your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
# Get from: Google Cloud Console → APIs & Services → Credentials
# Required for Google Sign-In functionality
# Command: bunx convex env set AUTH_GOOGLE_SECRET your-client-secret
AUTH_GOOGLE_SECRET=your-client-secret

# For GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Site URL
# Base URL for OAuth redirects and deep links (can be preview URL)
# Auto-derived from VERCEL_URL for preview deployments
# Note: For email images, use EMAIL_ASSET_URL (always production)
# Command: bunx convex env set SITE_URL https://yourapp.com
SITE_URL=https://yourapp.com

# ====================================
# E2E Testing (REQUIRED for test setup)
# ====================================

# E2E Test Secret
# Used by Playwright globalSetup to create/verify/delete test users
# Test users are created with unique emails each run and deleted after tests
# Must match the value in your local .env.test file
# Generate with: openssl rand -base64 32
# Command: bunx convex env set AUTH_E2E_TEST_SECRET your-secret-here
AUTH_E2E_TEST_SECRET=your-secure-random-test-secret

# ====================================
# Autumn Billing System (REQUIRED for billing features)
# ====================================

# Autumn Secret Key
# Get from: https://useautumn.com → Settings → API Keys
# Used for integrating pricing, subscriptions, and billing
# Command: bunx convex env set AUTUMN_SECRET_KEY am_sk_your_secret_key_here
AUTUMN_SECRET_KEY=am_sk_your_secret_key_here

# ====================================
# AI Customer Support (REQUIRED for AI chat features)
# ====================================

# OpenRouter API Key (REQUIRED)
# Get from: https://openrouter.ai/settings/keys
# Used for AI-powered customer support chat
# Free tier available with generous limits (GLM 4.5 Air, Grok 4 Fast, DeepSeek V3.1, etc.)
# Note: Some models require :free suffix (e.g., z-ai/glm-4.5-air:free)
# Command: bunx convex env set OPENROUTER_API_KEY sk-or-v1-your_openrouter_api_key_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# ====================================
# Self-Hosted Backend (process env vars)
# ====================================
# These are NOT Convex deployment env vars — they configure the backend binary itself.
# For Coolify/Docker: set as container environment variables.
# For local dev (`bun run dev`): auto-configured in vite.config.ts.

# V8 isolate heap size limit (bytes). Default is 64 MiB (67108864).
# Better Auth's bundle alone uses ~50 MiB, leaving almost no room for user code.
# Raise to 128 MiB to avoid TooMuchMemoryCarryOver restarts.
# See: https://github.com/get-convex/convex-backend/issues/312
ISOLATE_MAX_USER_HEAP_SIZE=134217728

# ====================================
# How to set these in Convex:
# ====================================
# For development deployment:
#   bunx convex env set KEY value
#
# For production deployment:
#   bunx convex env set KEY value --prod
#
# To view all environment variables:
#   bunx convex env list
#   bunx convex env list --prod
#
# To remove an environment variable:
#   bunx convex env unset KEY
#   bunx convex env unset KEY --prod
